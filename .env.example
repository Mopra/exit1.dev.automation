# ── HTTP receiver ──────────────────────────────────────────────
PORT=3000
WEBHOOK_PATH=/webhook
# Shared HMAC key. If set, each delivery must carry a valid
# `X-Exit1-Signature: sha256=<hmac>` header — HMAC-SHA256 of the raw request
# body keyed by this value. Set the SAME value in exit1.dev's webhook config.
# WEBHOOK_SECRET=replace-me-with-a-long-random-string

# ── Publish safety ─────────────────────────────────────────────
# DRY_RUN=true generates + logs the post but sends NOTHING to X.
# Defaults to true. Flip to false ONLY after X creds are set and you've
# watched a few dry-run deliveries look correct.
DRY_RUN=true

# ── X (Twitter) API — OAuth 1.0a user context ──────────────────
# Create an app at developer.x.com, set it to "Read and Write", then
# regenerate the Access Token/Secret AFTER setting that permission.
# The access token must belong to the account that should post.
# X_API_KEY=
# X_API_SECRET=
# X_ACCESS_TOKEN=
# X_ACCESS_TOKEN_SECRET=

# ── AI copy (OpenRouter) ───────────────────────────────────────
# Without a key, posts use the deterministic template (still fine).
# OPENROUTER_API_KEY=sk-or-v1-...
# Best human-sounding brand voice: anthropic/claude-sonnet-4.5 (default).
# Cheaper, more template-prone: anthropic/claude-3.5-haiku, openai/gpt-4o-mini.
# Post volume is low (budget below), so even Sonnet costs cents/month.
OPENROUTER_MODEL=anthropic/claude-sonnet-4.5
# OPENROUTER_REFERER=https://exit1.dev
# OPENROUTER_TITLE=exit1.dev status bot
# OPENROUTER_TIMEOUT_MS=12000
# Sampling temperature. Higher = more varied/human, but too high makes the
# model confabulate cause/impact about famous hosts. Variety mainly comes from
# angle nudges + recent-post memory + repetition penalties, so this stays moderate.
# OPENROUTER_TEMPERATURE=0.85
# How many recent post texts to feed the model as "don't echo these".
# COPY_RECENT_MEMORY=8

# ── Posting policy ─────────────────────────────────────────────
# Self-imposed budget so we never hit X's write quota. Defaults are
# sized for the lowest (Free legacy) ceilings (~50/24h, ~500/mo).
POST_BUDGET_PER_DAY=30
POST_BUDGET_PER_MONTH=400
# After a site recovers, suppress a NEW down-post for this long (ms) so a
# flapping site can't spam the timeline. Default 15 min.
FLAP_COOLDOWN_MS=900000

# Brand strings used in copy / fallback template. BRAND_URL is the website —
# both the home fallback and the base for status-page links.
BRAND_URL=https://exit1.dev
BRAND_NAME=exit1.dev
# Append a link to each post: the affected site's public status page
# (exit1.dev/status/<slug>), or the home page if it has no status page.
# Default on — it's the call to action. Set to false to drop the link.
INCLUDE_LINK=true

# Public-monitors index (app.exit1.dev) used to map a monitored site to its
# status-page slug. Cached in-memory for STATUS_INDEX_TTL_MS between fetches.
# STATUS_API_BASE=https://app.exit1.dev
# STATUS_INDEX_TTL_MS=600000
# STATUS_API_TIMEOUT_MS=8000

# ── Persistence ────────────────────────────────────────────────
# JSON state file (open incidents, budget ledger, flap cooldowns).
# MUST live on a persistent volume in production, or restarts lose
# threading state and the budget counter.
STATE_FILE=./data/state.json
